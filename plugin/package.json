{
  "name": "brain",
  "version": "0.1.0",
  "description": "OpenCode brain plugin with vector memory",
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    ".": {
      "import": "./dist/plugin.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message",
      "event"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@opencode-ai/plugin": "^1.3.0",
    "@opencode-ai/sdk": "^1.3.0",
    "franc-min": "^6.2.0",
    "iso-639-3": "^3.0.1",
    "stopword": "^3.1.5",
    "usearch": "^2.21.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@types/stopword": "^2.0.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
