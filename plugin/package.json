{
  "name": "brain",
  "version": "0.1.0",
  "description": "OpenCode brain plugin with vector memory",
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    ".": {
      "import": "./dist/plugin.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "opencode": {
    "type": "plugin",
    "hooks": ["chat.message", "event"]
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.0",
    "@opencode-ai/sdk": "^1.3.0",
    "@huggingface/transformers": "^4.2.0",
    "usearch": "^2.21.4",
    "zod": "^4.3.6",
    "franc-min": "^6.2.0",
    "iso-639-3": "^3.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
