{
  "name": "brain",
  "version": "0.1.0",
  "description": "OpenCode brain plugin with vector memory",
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    ".": {
      "import": "./dist/plugin.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:ui": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message",
      "event"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@opencode-ai/plugin": "^1.3.0",
    "@opencode-ai/sdk": "^1.3.0",
    "franc-min": "^6.2.0",
    "iso-639-3": "^3.0.1",
    "stopword": "^3.1.5",
    "usearch": "^2.21.4",
    "zod": "^4.3.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@types/stopword": "^2.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "postcss": "^8.5.16",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
